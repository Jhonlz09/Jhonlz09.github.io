---
import Section from "../Section.astro"

import { education } from "@cv"
const { class: className } = Astro.props;
---

<Section title="Educación" class={`education-section ${className || ''}`}>
  <ul>
    {
      education.map(({ institution, startDate, endDate, area, studyType }) => {
        const startYear = new Date(startDate).getFullYear()
        const endYear =
          endDate != null ? new Date(endDate).getFullYear() : "Actual"
        const years = `${startYear} - ${endYear}`

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{institution}</h3>
                </div>

                <time style="text-align:end">{years}</time>
              </header>

              <footer>
                <p>{studyType} en {area}</p>
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  article h3 {
    font-weight: 500;
    color: var(--text-primary);
    font-size: 1.05rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-tertiary);
    font-size: var(--fs-xs);
    min-width: 102px;
  }

  footer p {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
