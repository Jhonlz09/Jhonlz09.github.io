---
import { basics } from "@cv"
import Section from "@/components/Section.astro"
import Phone from "@/icons/Phone.astro"
import LinkedIn from "@/icons/LinkedIn.astro"
import GitHub from "@/icons/GitHub.astro"
import WorldMap from "@/icons/WorldMap.astro"
import type { SocialIcon } from "@/types"

const { name, label, image, location, profiles, phone, email, summary } = basics
const { city, region } = location

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn,
  Phone
}

const linkedInfo = profiles.find(({ network }) => network === "LinkedIn")
const linkedUrl = linkedInfo?.url

const printInfo = [email, phone, linkedUrl].filter(Boolean).join(" • ")
const { class: className } = Astro.props;
---

<Section class={`hero-section ${className || ''}`}>
  <div class="container">
    <div class="info">
      <h1>{name}</h1>
      <h2>{label}</h2>
      <p class="summary">{summary}</p>
      <span>
        <WorldMap />
        {city}, {region}
      </span>
      <footer class="print">
        {printInfo}
      </footer>
      <footer class="no-print actions">
        {
          email && (
            <a
              href={`mailto:${email}`}
              title={`Enviar un correo electrónico a ${name} al correo ${email}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cta primary"
            >
              Contactar
            </a>
          )
        }
        <div class="socials">
          {
            phone && (
              <a
                href={`tel:${phone}`}
                title={`Llamar a ${name} al ${phone}`}
                class="cta secondary"
                rel="noopener noreferrer"
              >
                <Phone />
              </a>
            )
          }
          {
            profiles.map(({ network, url }) => {
              const Icon = SOCIAL_ICONS[network]
              return (
                <a
                  href={url}
                  title={`Visitar el perfil de ${name} en ${network}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cta secondary"
                >
                  <Icon />
                </a>
              )
            })
          }
        </div>
      </footer>
    </div>
    <figure class="profile-figure">
      <img src={image} alt={name} />
    </figure>
  </div>
</Section>

<style>
  .hero-section {
    background: var(--bg-card);
  }

  .container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 100%;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    flex: 1;
  }

  .badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .pulse {
    width: 6px;
    height: 6px;
    background-color: #10b981;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 8px #10b981;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
    70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  h1 {
    font-size: var(--fs-display);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(to bottom right, #fafafa, #a1a1aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  h2 {
    color: var(--text-primary);
    font-weight: 600;
    font-size: var(--fs-lg);
    text-wrap: balance;
  }

  .summary {
    color: var(--text-secondary);
    font-size: var(--fs-base);
    line-height: 1.6;
    max-width: 90%;
  }

  .profile-figure {
    position: relative;
    border-radius: var(--radius-xl);
    padding: 4px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0));
    border: 1px solid var(--border-subtle);
  }

  img {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    width: 128px;
    border-radius: var(--radius-lg);
    filter: grayscale(100%) contrast(1.2);
    transition: filter 0.5s var(--ease-out);
  }

  img:hover {
    filter: grayscale(0%) contrast(1);
  }

  span {
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-sm);
    font-weight: 500;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-2);
  }

  .socials {
    display: flex;
    gap: var(--sp-2);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-weight: 600;
    transition: all var(--duration-fast) var(--ease-out);
    text-decoration: none;
    cursor: pointer;
  }

  .cta.primary {
    background: var(--accent);
    color: #fff;
    border: none;
    box-shadow: 0 4px 14px 0 rgba(139, 92, 246, 0.3);
  }

  .cta.primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.35);
  }

  .cta.secondary {
    background: var(--bg-elevated);
    color: var(--text-primary);
    border: 1px solid var(--border-default);
    padding: 0.6rem;
  }

  .cta.secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--border-hover);
    transform: translateY(-1px);
  }

  @media (max-width: 700px) {
    .container {
      flex-direction: column-reverse;
      text-align: center;
    }
    .info {
      align-items: center;
    }
    .summary {
      max-width: 100%;
    }
    h1 {
      font-size: var(--fs-4xl);
    }
    .actions {
      flex-direction: column;
      width: 100%;
    }
    .cta.primary {
      width: 100%;
    }
  }

  @media print {
    .pulse {
      display: none !important;
    }
    .badge {
      border: 1px solid #000 !important;
      background: transparent !important;
      color: #000 !important;
    }
    h1 {
      background: none !important;
      -webkit-text-fill-color: #000 !important;
      color: #000 !important;
    }
    .profile-figure {
      background: none !important;
      border: none !important;
      padding: 0 !important;
    }
    img {
      filter: none !important;
      width: 120px !important;
    }
    .info {
      gap: 0.5rem !important;
    }
  }
</style>
