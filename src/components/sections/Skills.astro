---
import Section from "../Section.astro"
import HTML from "@/icons/html.astro"
import CSS from "@/icons/css.astro"
import JavaScript from "@/icons/javascript.astro"
import TypeScript from "@/icons/type.astro"
import React from "@/icons/react.astro"
import Node from "@/icons/node.astro"
import MySQL from "@/icons/sql.astro"
import Git from "@/icons/git.astro"
import GitHub from "@/icons/GitHub.astro"
import Tailwind from "@/icons/tailwind.astro"
import Next from "@/icons/next.astro"
import { skills } from "@cv"
import Swift from "@/icons/swift.astro"
import SwiftUI from "@/icons/swiftui.astro"
import Kotlin from "@/icons/kotlin.astro"
import Flutter from "@/icons/flutter.astro"
import Php from "@/icons/php.astro"
import Python from "@/icons/python.astro"


const SKILLS_ICONS: Record<string, any> = {
  HTML,
  CSS,
  JavaScript,
  TypeScript,
  React,
  Node,
  MySQL,
  Git,
  GitHub,
  Next,
  Tailwind,
  Swift,
  SwiftUI,
  Kotlin,
  Flutter,
  Php,
  Python
}
const { class: className } = Astro.props;
---

<Section title="Stack Tecnológico" class={`skills-section ${className || ''}`}>
  <div class="skills-container">
    {
      skills.map(({ name, keywords }) => (
        <div class="skill-group">
          <h3>{name}</h3>
          <ul>
            {keywords.map((keyword) => {
              const iconName = keyword === "Next.js" ? "Next" : keyword === "Tailwind CSS" ? "Tailwind" : keyword === "Node.js" ? "Node" : keyword
              const Icon = SKILLS_ICONS[iconName]
      
              return (
                <li>
                  {Icon && <Icon />} <span>{keyword}</span>
                </li>
              )
            })}
          </ul>
        </div>
      ))
    }
  </div>
</Section>

<style>
  .skills-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-group h3 {
    font-size: var(--fs-xs);
    color: var(--text-tertiary);
    margin-bottom: var(--sp-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  ul {
    display: inline-flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }

  li {
    align-items: center;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    display: flex;
    font-size: var(--fs-sm);
    font-weight: 500;
    gap: var(--sp-2);
    padding: var(--sp-1) var(--sp-3);
  }

  @media print {
    li {
      background: transparent !important;
      border: 1px solid #ccc !important;
      color: #000 !important;
      page-break-inside: avoid;
    }
    .skill-group h3 {
      color: #000 !important;
    }
  }
</style>
