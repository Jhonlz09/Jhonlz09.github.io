---
import Layout from "@/layouts/Layout.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import DownloadPDF from "@/components/DownloadPDF.astro";

import { basics } from "@cv";
const { name } = basics;
---

<Layout title={`${name} · Full-Stack Developer | Guayaquil, Ecuador`}>
  <main>
    <Hero class="bento-hero" />
    <Experience class="bento-experience" />
    <Projects class="bento-projects" />
    <Skills class="bento-skills" />
    <Education class="bento-education" />
  </main>

  <DownloadPDF />
</Layout>

<style>
  main {
    padding: var(--sp-8);
    margin: auto;
    width: 100%;
    max-width: 1200px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(min-content, max-content);
    gap: var(--sp-3);
  }

  @media (max-width: 1024px) {
    main {
      grid-template-columns: repeat(4, 1fr);
      padding: var(--sp-6);
    }
  }

  @media (max-width: 700px) {
    main {
      grid-template-columns: 1fr;
      padding: var(--sp-4);
      gap: var(--sp-3);
    }
  }
</style>

<style is:global>
  .bento-hero { grid-column: span 6; }
  .bento-experience { grid-column: span 6; }
  .bento-projects { grid-column: span 6; }
  .bento-skills { grid-column: span 3; }
  .bento-education { grid-column: span 3; }

  @media (max-width: 1024px) {
    .bento-hero { grid-column: span 4; }
    .bento-experience { grid-column: span 4; }
    .bento-projects { grid-column: span 4; }
    .bento-skills { grid-column: span 2; }
    .bento-education { grid-column: span 2; }
  }

  @media (max-width: 700px) {
    .bento-hero { grid-column: span 1; }
    .bento-experience { grid-column: span 1; }
    .bento-projects { grid-column: span 1; }
    .bento-skills { grid-column: span 1; }
    .bento-education { grid-column: span 1; }
  }
</style>
